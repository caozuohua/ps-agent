# Lark International
LARK_APP_ID=cli_xxx
LARK_APP_SECRET=xxx
LARK_VERIFICATION_TOKEN=
LARK_ENCRYPT_KEY=
# User binding
# 首次可先留空，通过 /id 获取 open_id 后再填写
BIND_OPEN_ID=
# Runtime
DATA_DIR=./data
SQLITE_PATH=./data/agent.db
LOG_LEVEL=INFO
# Lark message
LARK_TEXT_CHUNK_SIZE=3000

# Phase 2 shell execution
DEFAULT_SHELL_MODE=sandbox
DEFAULT_SHELL_TIMEOUT=10
MAX_SHELL_TIMEOUT=120
DOCKER_IMAGE=alpine:latest
SANDBOX_NETWORK=none
# Host mode
ENABLE_HOST_MODE=true
HOST_MODE_REQUIRE_CONFIRM=true
# Confirmation
CONFIRM_EXPIRE_SECONDS=300
# Security
ENABLE_COMMAND_BLACKLIST=true
